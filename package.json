{
  "name": "anon-chat",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "latest",
    "@vueuse/core": "^14.3.0",
    "centrifuge": "^5.7.0",
    "vue": "^3.5.39",
    "vue-router": "^5.2.0",
    "vue-tg": "^0.10.0",
    "express": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vue-tsc": "^3.3.5",
    "tsx": "^4.19.1",
    "esbuild": "^0.23.0"
  }
